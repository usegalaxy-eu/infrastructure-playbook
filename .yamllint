---
extends: default

ignore: |
  files/clouds.yaml
  group_vars/all/ssh-keys_vault.yml
  group_vars/beacon/vault.yml
  group_vars/grafana/vault.yml
  group_vars/htcondor/vault.yml
  roles
  collections
  one-off
  secret_group_vars
  templates
  files/galaxy/config
  files/galaxy-test/config
  files/galaxy-test/dynamic_rules/usegalaxy/
  files/traefik/rules/template*

rules:
  line-length: disable
  comments-indentation: disable  # don't bother me with this rule
  comments:
    require-starting-space: false
    min-spaces-from-content: 1
