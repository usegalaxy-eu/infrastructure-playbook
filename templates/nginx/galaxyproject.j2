server {
	listen 443 ssl;
	listen [::]:443 ssl;

	server_name galaxyproject.eu;

	# Homepage.
	location = / {
		return 301 https://galaxyproject.org/eu/;
	}
	location ~* "^/eu/?$" {
		return 301 https://galaxyproject.org/eu/;
	}

	# EU-wide news/events feeds.
	location ~* "^/news(?:\.html|/)?$" {
		return 301 https://galaxyproject.org/eu/news/;
	}
	location ~* "^/events(?:\.html|/)?$" {
		return 301 https://galaxyproject.org/eu/events/;
	}

	# Pages embedded by Galaxy servers.
	location ~* "^/galaxy/news(?:\.html|/)?$" {
		return 301 https://galaxyproject.org/bare/eu/news/;
	}
	location ~* "^/galaxy/events(?:\.html|/)?$" {
		return 301 https://galaxyproject.org/bare/eu/events/;
	}

	# Galaxy server middle pane homepage.
	location = /galaxy/ {
		return 301 https://galaxyproject.org/bare/eu/usegalaxy/main/;
	}

	# ---------------------------------------------------------------------------
	# Legacy galaxyproject.eu -> galaxyproject.org (hub) 301 redirect table.
	# Generated from the galaxy-eu-migration-audit manifest (schema v3).
	#
	# Exact `location =` blocks are used for news posts and events: the hub does
	# not normalise slug case/spelling (and several events were re-dated on
	# migration), while stock nginx cannot lower-case in a rewrite. Each key is
	# the real published legacy URL and each target was verified to resolve.
	# Regex rules are used only where the transform is provably deterministic.
	# ---------------------------------------------------------------------------

	# Fold plain-text / ICS variants onto the canonical path so that a single
	# exact block per item suffices (URI case is preserved by the rewrite).
	rewrite "^/posts/(\d{4})/(\d{2})/(\d{2})/(.+?)(?:-plain|/plain\.html)/?$" /posts/$1/$2/$3/$4/ last;
	rewrite "^/event/(.+?)(?:-plain|/plain\.html|/event\.ics(?:\.html)?)/?$" /event/$1/ last;

	# Galaxy subdomain landing pages: /index-<name>[.html] -> /bare/eu/usegalaxy/<name>/
	# Overrides first (exact match always beats regex in nginx).
	location = /index-microgalaxy.html { return 301 https://microbiology.usegalaxy.eu/; }
	location = /index-microgalaxy/ { return 301 https://microbiology.usegalaxy.eu/; }
	location = /index-microbiome.html { return 301 https://galaxyproject.org/eu/; }
	location = /index-microbiome/ { return 301 https://galaxyproject.org/eu/; }
	location = /index-ssh.html { return 301 https://galaxyproject.org/eu/; }
	location = /index-ssh/ { return 301 https://galaxyproject.org/eu/; }
	location = /index-test.html { return 301 https://galaxyproject.org/eu/; }
	location = /index-test/ { return 301 https://galaxyproject.org/eu/; }
	# Case-sensitive: the capture is interpolated into the target.
	location ~ "^/index-([a-z0-9][a-z0-9-]*)(?:\.html|/)?$" { return 301 https://galaxyproject.org/bare/eu/usegalaxy/$1/; }

	# Core EU informational pages.
	location ~* "^/about(?:\.html|/)?$" { return 301 https://galaxyproject.org/eu/about/; }
	location ~* "^/tools(?:\.html|/)?$" { return 301 https://galaxyproject.org/eu/tools/; }
	location ~* "^/citations(?:\.html|/)?$" { return 301 https://galaxyproject.org/eu/citations/; }
	location ~* "^/tiaas(?:\.html|/)?$" { return 301 https://galaxyproject.org/eu/tiaas/; }
	location ~* "^/gga(?:\.html|/)?$" { return 301 https://galaxyproject.org/use/gga/; }
	location ~* "^/ftp/?$" { return 301 https://galaxyproject.org/ftp-upload/; }
	location ~* "^/widgets/?$" { return 301 https://galaxyproject.org/eu/widgets/; }
	location ~* "^/widgets/news(?:\.html|/)?$" { return 301 https://galaxyproject.org/bare/eu/latest/news/; }
	location ~* "^/widgets/events(?:\.html|/)?$" { return 301 https://galaxyproject.org/bare/eu/latest/events/; }

	# Member (subsite) pages: news/events keep their feed, anything else that was
	# not migrated falls back to the subsite home page on the hub.
	location ~* "^/belgium/news(?:\.html|/)?$" { return 301 https://galaxyproject.org/belgium/news/; }
	location ~* "^/belgium/events(?:\.html|/)?$" { return 301 https://galaxyproject.org/belgium/events/; }
	location ~* "^/elixir-it/news(?:\.html|/)?$" { return 301 https://galaxyproject.org/elixir-it/news/; }
	location ~* "^/elixir-it/events(?:\.html|/)?$" { return 301 https://galaxyproject.org/elixir-it/events/; }
	location ~* "^/erasmusmc/news(?:\.html|/)?$" { return 301 https://galaxyproject.org/erasmusmc/news/; }
	location ~* "^/erasmusmc/events(?:\.html|/)?$" { return 301 https://galaxyproject.org/erasmusmc/events/; }
	location ~* "^/freiburg/news(?:\.html|/)?$" { return 301 https://galaxyproject.org/freiburg/news/; }
	location ~* "^/freiburg/events(?:\.html|/)?$" { return 301 https://galaxyproject.org/freiburg/events/; }
	location ~* "^/genouest/news(?:\.html|/)?$" { return 301 https://galaxyproject.org/genouest/news/; }
	location ~* "^/genouest/events(?:\.html|/)?$" { return 301 https://galaxyproject.org/genouest/events/; }
	location ~* "^/ifb/news(?:\.html|/)?$" { return 301 https://galaxyproject.org/ifb/news/; }
	location ~* "^/ifb/events(?:\.html|/)?$" { return 301 https://galaxyproject.org/ifb/events/; }
	location ~* "^/pasteur/news(?:\.html|/)?$" { return 301 https://galaxyproject.org/pasteur/news/; }
	location ~* "^/pasteur/events(?:\.html|/)?$" { return 301 https://galaxyproject.org/pasteur/events/; }
	location ~* "^/belgium(?:/.*)?$" { return 301 https://galaxyproject.org/belgium/; }
	location ~* "^/elixir-it(?:/.*)?$" { return 301 https://galaxyproject.org/elixir-it/; }
	location ~* "^/erasmusmc(?:/.*)?$" { return 301 https://galaxyproject.org/erasmusmc/; }
	location ~* "^/freiburg(?:/.*)?$" { return 301 https://galaxyproject.org/freiburg/; }
	location ~* "^/genouest(?:/.*)?$" { return 301 https://galaxyproject.org/genouest/; }
	location ~* "^/ifb(?:/.*)?$" { return 301 https://galaxyproject.org/ifb/; }
	location ~* "^/pasteur(?:/.*)?$" { return 301 https://galaxyproject.org/pasteur/; }

